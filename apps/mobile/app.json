{
  "expo": {
    "name": "Intelligent Bistro",
    "slug": "intelligent-bistro",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "bistro",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "backgroundColor": "#0B0B0E",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bistro.intelligent"
    },
    "android": {
      "package": "com.bistro.intelligent"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": ""
    }
  }
}
